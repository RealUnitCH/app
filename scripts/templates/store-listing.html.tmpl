<details id="spec-store-listing" class="spec" open>
  <summary>
    <div class="spec-head">
      <div class="lhs">
        <h2><span class="num">S</span>App Store / Play Store Listing</h2>
        <div class="file">ios/fastlane/metadata · android/fastlane/metadata</div>
      </div>
      <div class="rhs">
        <b>Live aus Repo</b>
        <div class="links">
          <a href="https://github.com/RealUnitCH/app/tree/main/ios/fastlane/metadata">iOS metadata ↗</a>
          ·
          <a href="https://github.com/RealUnitCH/app/tree/main/android/fastlane/metadata/android">Android metadata ↗</a>
        </div>
      </div>
    </div>
  </summary>

  <p class="spec-intro">
    Single source of truth für alles, was an Apple App Store Connect und
    Google Play Console übermittelt wird. Änderung an Text, Screenshot
    oder Feature Graphic geht ausschliesslich über einen PR auf diese
    Dateien; <code>store-metadata.yaml</code> pusht den neuen Stand an
    beide Konsolen, und der nächste Handbook-Build rendert ihn hier neu.
  </p>

  <!-- iOS section -->
  <h3>Apple App Store (de-DE)</h3>
  <dl class="store-listing">
    <dt>App-Name (max 30)</dt><dd><code>{{ ios_name }}</code></dd>
    <dt>Untertitel (max 30)</dt><dd><code>{{ ios_subtitle }}</code></dd>
    <dt>Beschreibung (max 4000)</dt><dd><pre>{{ ios_description }}</pre></dd>
    <dt>Schlagwörter (max 100, kommasepariert)</dt><dd><code>{{ ios_keywords }}</code></dd>
    <dt>Marketing-URL</dt><dd><a href="{{ ios_marketing_url }}">{{ ios_marketing_url }}</a></dd>
    <dt>Privacy-URL</dt><dd><a href="{{ ios_privacy_url }}">{{ ios_privacy_url }}</a></dd>
    <dt>Support-URL</dt><dd><a href="{{ ios_support_url }}">{{ ios_support_url }}</a></dd>
    <dt>Copyright</dt><dd>{{ ios_copyright }}</dd>
    <dt>Release-Notes</dt><dd>{{ ios_release_notes }}</dd>
  </dl>

  <h4>Screenshots — iPhone 6.9 Display (1320×2868)</h4>
  <div class="store-screenshots">
    <figure><img src="../store/ios/iphone-69/01_welcome.png"   alt="Welcome"/><figcaption>01_welcome</figcaption></figure>
    <figure><img src="../store/ios/iphone-69/02_dashboard.png" alt="Dashboard"/><figcaption>02_dashboard</figcaption></figure>
    <figure><img src="../store/ios/iphone-69/03_security.png"  alt="Security"/><figcaption>03_security</figcaption></figure>
    <figure><img src="../store/ios/iphone-69/04_buy.png"       alt="Buy"/><figcaption>04_buy</figcaption></figure>
    <figure><img src="../store/ios/iphone-69/05_tax.png"       alt="Tax"/><figcaption>05_tax</figcaption></figure>
  </div>

  <h4>Screenshots — iPad Pro 13" Display (2752×2064)</h4>
  <div class="store-screenshots">
    <figure><img src="../store/ios/ipad-13/01_welcome.png"   alt="Welcome"/><figcaption>01_welcome</figcaption></figure>
    <figure><img src="../store/ios/ipad-13/02_dashboard.png" alt="Dashboard"/><figcaption>02_dashboard</figcaption></figure>
    <figure><img src="../store/ios/ipad-13/03_security.png"  alt="Security"/><figcaption>03_security</figcaption></figure>
    <figure><img src="../store/ios/ipad-13/04_buy.png"       alt="Buy"/><figcaption>04_buy</figcaption></figure>
    <figure><img src="../store/ios/ipad-13/05_tax.png"       alt="Tax"/><figcaption>05_tax</figcaption></figure>
  </div>

  <!-- Android section -->
  <h3>Google Play Store (de-DE)</h3>
  <dl class="store-listing">
    <dt>Titel (max 50)</dt><dd><code>{{ android_title }}</code></dd>
    <dt>Kurzbeschreibung (max 80)</dt><dd>{{ android_short }}</dd>
    <dt>Lang-Beschreibung (max 4000, HTML)</dt><dd><div class="rendered-html">{{ android_full_html }}</div></dd>
    <dt>Changelog</dt><dd>{{ android_changelog }}</dd>
  </dl>

  <h4>Feature Graphic (1024×500)</h4>
  <figure class="store-graphic"><img src="../store/android/featureGraphic.png" alt="Feature Graphic"/></figure>

  <h4>Icon (512×512)</h4>
  <figure class="store-icon"><img src="../store/android/icon.png" alt="App Icon"/></figure>

  <h4>Phone Screenshots (1350×2400)</h4>
  <div class="store-screenshots">
    <figure><img src="../store/android/phone/01_welcome.png"   alt="Welcome"/><figcaption>01_welcome</figcaption></figure>
    <figure><img src="../store/android/phone/02_dashboard.png" alt="Dashboard"/><figcaption>02_dashboard</figcaption></figure>
    <figure><img src="../store/android/phone/03_security.png"  alt="Security"/><figcaption>03_security</figcaption></figure>
    <figure><img src="../store/android/phone/04_buy.png"       alt="Buy"/><figcaption>04_buy</figcaption></figure>
