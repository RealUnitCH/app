# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

def get_api_key
  app_store_connect_api_key(
    key_id: ENV['FASTLANE_APPLE_API_KEY_ID'],
    issuer_id: ENV['FASTLANE_APPLE_API_ISSUER_ID'],
    key_filepath: ENV['FASTLANE_APPLE_API_KEY_PATH'],
  )
end

# --- Define Keychain Setup for CI ---
def setup_ci_keychain
  keychain_name = "ci_keychain"
  keychain_password = ENV["KEYCHAIN_PASSWORD"]

  create_keychain(
    name: keychain_name,
    password: keychain_password,
    default_keychain: true,
    unlock: true,
    timeout: 3600 # Keep unlocked for 1 hour
  )
end

# --- Define Keychain Cleanup ---
def cleanup_ci_keychain
  keychain_name = "ci_keychain"
  delete_keychain(name: keychain_name)
end

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do

    setup_ci_keychain

    keychain_name = "ci_keychain"
    keychain_password = ENV["KEYCHAIN_PASSWORD"]

    match(
      type: "appstore",
      app_identifier: "swiss.dfx.realunit",
      api_key: get_api_key,
      keychain_name: "ci_keychain",
      keychain_password: ENV["KEYCHAIN_PASSWORD"],
      git_url: "git@github.com:DFXswiss/fastlane-certificates.git"
    )

    increment_build_number(xcodeproj: "Runner.xcodeproj")

    update_code_signing_settings(
        path: "Runner.xcodeproj", 
        keychain_path: "/Users/runner/Library/Keychains/ci_keychain-db" 
    )
    
    gym(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      # export_xcargs: '-allowProvisioningUpdates',
      export_options: {
        signingStyle: "manual"
      }
    )

    upload_to_testflight(
      api_key: get_api_key,
      skip_waiting_for_build_processing: true
    )

    cleanup_ci_keychain
  end
end
