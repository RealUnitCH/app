# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

def get_api_key
  app_store_connect_api_key(
    key_id: ENV['FASTLANE_APPLE_API_KEY_ID'],
    issuer_id: ENV['FASTLANE_APPLE_API_ISSUER_ID'],
    key_filepath: ENV['FASTLANE_APPLE_API_KEY_PATH'],
  )
end

# Runs tool/generate_release_info.dart (single source of truth for tag →
# marketing version + version code) and reads the values back from the
# generated Dart file. The generated file is the canonical artefact —
# parsing stdout is brittle because `dart run` prepends "Running build
# hooks..." with no trailing newline. Same helper is mirrored in
# android/fastlane/Fastfile.
def resolve_release_info(raw_tag)
  generated = Dir.chdir("../..") do
    sh("dart", "run", "tool/generate_release_info.dart", "--tag=#{raw_tag}")
    File.read("lib/generated/release_info.dart")
  end

  info = {
    "release_tag"       => generated.match(/releaseTag = '([^']+)'/)&.[](1),
    "marketing_version" => generated.match(/releaseMarketingVersion = '([^']+)'/)&.[](1),
    "version_code"      => generated.match(/releaseVersionCode = (\d+)/)&.[](1),
  }
  missing = info.select { |_, v| v.nil? }.keys
  UI.user_error!("release-info generator missing keys: #{missing.join(', ')}") unless missing.empty?
  # `dev` sentinel (versionCode=0) is intended for local builds only —
  # TestFlight rejects build number 0. Fail loudly before invoking gym.
  if info["version_code"].to_i <= 0
    UI.user_error!("refusing to build a store release without a release tag (got: '#{raw_tag}')")
  end
  info
end

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    setup_ci

    raw_version_name = ENV["NEW_VERSION"] || "v0.0.0"
    info = resolve_release_info(raw_version_name)
    tag_name = info["release_tag"]
    marketing_version = info["marketing_version"]
    version_code = info["version_code"]

    sync_code_signing(
      type: "appstore",
      app_identifier: "swiss.realunit.app",
      api_key: get_api_key,
      git_url: "git@github.com:DFXswiss/fastlane-certificates.git"
    )

    # CFBundleShortVersionString must be three integers (App Store ITMS-90060).
    # The marketing version equals the bare tag (e.g. "1.0.15"). The build number is
    # tag-deterministic and identical to the Android versionCode (see
    # tool/generate_release_info.dart).
    increment_version_number(
      version_number: marketing_version,
      xcodeproj: "Runner.xcodeproj"
    )

    increment_build_number(
      build_number: version_code,
      xcodeproj: "Runner.xcodeproj"
    )

    gym(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      output_name: "realunit-#{tag_name}.ipa",
      xcargs: "-verbose",
      verbose: true
    )

    upload_to_testflight(
      api_key: get_api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
