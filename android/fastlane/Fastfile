# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:android)

platform :android do
  
  def built_aab_path
    return "../build/app/outputs/bundle/release/app-release.aab"
  end

  def get_next_build_number
    internal_codes = google_play_track_version_codes(track: 'internal') || []
    # beta_codes = google_play_track_version_codes(track: 'beta') || []
    # production_codes = google_play_track_version_codes(track: 'production') || []
    
    # all_version_codes = internal_codes + beta_codes + production_codes

    all_version_codes = internal_codes
    
    all_version_codes.empty? ? 1 : all_version_codes.max + 1
  end

  desc "Build and upload to Play Store Beta"
  lane :beta do
    new_build_number = get_next_build_number

    # Build the app bundle using Flutter CLI
    # We obfuscate and split debug info to keep the APK size down and secure
    sh("flutter", "build", "appbundle", 
       "--build-number=#{new_build_number}", 
       "--no-tree-shake-icons", 
       "--obfuscate", 
       "--split-debug-info=build/debug_info")

    # Upload to the 'beta' track as a 'draft'
    # Always upload as draft first so you can review it!
    upload_to_play_store(
      track: 'internal',
      aab: built_aab_path,
      release_status: 'draft'
    )
  end

  desc "Build and upload to Production"
  lane :production do
    # For production, we grab the semantic version (e.g., "1.2.0") from the environment
    new_version_name = ENV["NEW_VERSION"]
    new_build_number = get_next_build_number

    sh("flutter", "build", "appbundle", 
       "--build-number=#{new_build_number}", 
       "--no-tree-shake-icons", 
       "--build-name=#{new_version_name}", 
       "--obfuscate", 
       "--split-debug-info=build/debug_info")

    upload_to_play_store(
      track: 'production',
      aab: built_aab_path,
      release_status: 'draft'
    )
  end
end